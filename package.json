{
  "name": "ms-studios-premium-website",
  "version": "1.0.0",
  "private": true,
  "description": "Premium static TailwindCSS website for MS Studios Jaranwala.",
  "scripts": {
    "build:css": "tailwindcss -c tailwind.config.js -i ./css/input.css -o ./assets/css/styles.css --minify",
